# ── Required ────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Generate: openssl rand -base64 32
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── Frontend → Backend URL ────────────────────────────────────────────────────
# The URL the browser uses to reach the backend API.
# For a single-server setup this is usually http://<your-server-ip>:8000
# or https://api.yourdomain.com if you have TLS termination in front.
BACKEND_URL=http://localhost:8000
