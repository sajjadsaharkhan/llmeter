# ── Required ────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Generate: openssl rand -base64 32
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# ── Frontend → Backend ───────────────────────────────────────────────────────
# URL the browser uses to reach the backend API.
# Single-server: http://<your-ip>:8000  |  With TLS: https://api.yourdomain.com
BACKEND_URL=http://localhost:8000

# Comma-separated allowed CORS origins (must include wherever the frontend is served from)
CORS_ORIGINS=http://localhost:3000
